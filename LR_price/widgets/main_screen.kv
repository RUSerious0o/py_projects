#: include widgets/list_item.kv

<MainScreen>
    BoxLayout:
        orientation: 'horizontal'

    # БОКОВОЕ МЕНЮ
        BoxLayout:
            orientation: 'vertical'
            size_hint: 0.2, 1

            ToggleButton:
                text: "С/Р"
                state: 'down'
                on_release: root.change_sum(3350 if self.state == 'down' else -3350)

            Button:
                text: "Свернуть все"

            Button:
                text: "Сброс"
                on_release: root.reset_selection()

    # ОСНОНОЕ ОКНО
        BoxLayout:
            orientation: 'vertical'

            Label:
                id: sum_label
                sum_: 3350
                text: "Итого: 3350"
                font_size: 48
                size_hint: 1, 0.2

            ScrollView:
                bar_width: 10

                GridLayout:
                    id: list_items
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height

                    SectionLayout:
                        section_name: 'Подготовка'
                        id: preps_section

                    SectionLayout:
                        section_name: 'Чистка'
                        id: cleanse_section

                    SectionLayout:
                        section_name: 'Заправка'
                        id: refill_section

                    SectionLayout:
                        section_name: 'Дренаж'
                        id: water_drain_section

                    SectionLayout:
                        section_name: 'Прочее'
                        id: other_section

<SectionButton@ToggleButton>
    size_hint_y: None
    text_size: self.size
    halign: 'left'
    valign: 'middle'
    padding: 10
    font_size: 24

    background_normal: ''
    background_down: ''

    background_color: (0.2, 0.2, 0.6, 1) if self.state == 'down' else (0.2, 0.2, 0.2, 1)

    canvas.after:
        Color:
            #rgba: (0.2, 0.2, 0.2, 1)
            rgba: (1, 1, 1, 1)
        Line:
            points: [self.x, self.y, self.x + self.width, self.y]

<SectionLayout@BoxLayout>
    orientation: 'vertical'
    size_hint_y: None
    section_name: 'Имя раздела'

    SectionButton:
        text: root.section_name
        state: 'down'

        #on_release: content.disabled = not content.disabled
        #on_release: content.disabled = True; root.height = 50

    BoxLayout:
        id: content
        orientation: 'vertical'
        size_hint_y: None
        height: 0
